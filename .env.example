# Safe default: fictional demonstration data only.
ALLOW_REAL_PHI=false
HOSTING_BAA_CONFIRMED=false
GOOGLE_BAA_CONFIRMED=false
OPENAI_BAA_CONFIRMED=false
OPENAI_MODIFIED_RETENTION_CONFIRMED=false

FIREBASE_PROJECT_ID=careconnectai-19ace
# Recommended on Railway: Base64 avoids multiline/private-key formatting damage.
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Railway: paste the complete service-account JSON into a protected variable.
# Never commit its real value or send it in chat.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternative for systems that support secret-mounted files:
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json

ENABLE_OPENAI_PROVIDER_SEARCH=true
OPENAI_SEARCH_MODEL=gpt-5.4-mini
OPENAI_SEARCH_RESULT_LIMIT=3
OPENAI_SEARCH_TIMEOUT_SECONDS=16
OPENAI_EXPLANATION_TIMEOUT_SECONDS=5

ALLOWED_ORIGINS=https://careconnectai-19ace.firebaseapp.com,https://careconnectai-19ace.web.app
SEARCH_HISTORY_DB_PATH=/data/careconnect.db

# Security event storage and privacy-preserving identifiers.
SECURITY_EVENT_DB_PATH=/data/careconnect.db
# Generate with: openssl rand -hex 32
SECURITY_EVENT_HASH_KEY=replace-with-a-random-secret
SECURITY_ALERT_COOLDOWN_SECONDS=900

# Alerts can go to both founders. Use a transactional email/SMTP provider.
SECURITY_ALERT_EMAILS=founder@example.com,cofounder@example.com
SECURITY_ALERT_FROM=alerts@example.com
SECURITY_SMTP_HOST=
SECURITY_SMTP_PORT=587
SECURITY_SMTP_USERNAME=
SECURITY_SMTP_PASSWORD=

# Optional generic JSON webhook (Slack/Teams requires an adapter or workflow URL).
SECURITY_ALERT_WEBHOOK_URL=

# EmailJS REST delivery. When these are configured, EmailJS is used instead of SMTP.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Run monitor.py as a separate Railway service so it can detect backend downtime.
MONITOR_TARGET_URL=https://careconnect-ai-production-c747.up.railway.app/
MONITOR_INTERVAL_SECONDS=300
MONITOR_EXPECT_REAL_PHI=false
DEPLOYMENT_VERSION=local
